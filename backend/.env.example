# Copy this file to .env and fill in real values. Never commit the real .env file.

# MySQL running via XAMPP (default XAMPP MySQL user is "root" with empty password)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/hackathon_db

# Generate a real one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_string

ACCESS_TOKEN_EXPIRE_MINUTES=60

# Must match your Vite dev server URL
FRONTEND_ORIGIN=http://localhost:5173
